[app]
app_description	=	"WebDAV Server дозволяє користувачам редагувати файли, що зберігаються на віддалених серверах, та керувати ними. Якщо пакет WebDAV Server увімкнено, клієнтські програми з підтримкою WebDAV (наприклад, деякі застосунки Windows, Mac OS Finder або Linux File Browser) можуть отримувати віддалений доступ до Synology NAS так само, як при використанні локальних мережевих дисків."
app_name	=	"WebDAV Server"
wizard_do_not_upgrade_desc	=	"Починаючи з версії 2.4.0, WebDAV Server більше не підтримує CalDAV.<br><font class="red-status">Не оновлюйте до версії 2.4.0, якщо ви хочете продовжити використання CalDAV.</font>"
wizard_upgrade_desc	=	"WebDAV Server 2.4.0 і новіші версії більше не підтримують функцію календаря. Інструкції з перенесення календарів до Synology Calendar можна знайти в <a href="https://www.synology.com/knowledgebase/DSM/tutorial/File_Sharing/How_to_migrate_calendar_from_WebDAV_Server_to_Synology_Calendar" target="_blank">цій статті</a>."
wizard_upgrade_note	=	"Зверніть увагу, що після оновлення всі файли .ics зберігатимуться у вихідних теках."
wizard_upgrade_title	=	"Оновлення WebDAV Server"

